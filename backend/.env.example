# Copy to .env and fill in. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Signs login tokens. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# Never deploy with the built-in default — anyone who knows it can forge a login.
JWT_SECRET=

# Postgres. This default matches docker-compose.yml, so `docker compose up -d`
# and you are connected. Railway injects its own DATABASE_URL in production —
# the plain postgresql:// form is fine, the app rewrites it for asyncpg.
DATABASE_URL=postgresql+asyncpg://disciplined:disciplined@localhost:5432/disciplined

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash-lite
# ACCESS_TOKEN_EXPIRE_MINUTES=43200
